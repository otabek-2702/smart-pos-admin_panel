# Copy to `.env` and edit before running `docker compose up`.
# Vars consumed by docker-compose.yaml at the panel root.

# Required — fail-loud on missing.
SECRET_KEY=replace-with: python -c "import secrets; print(secrets.token_urlsafe(64))"
DB_PASSWORD=replace-with-a-strong-password

# Backend.
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,panel
DB_NAME=alpha_pos
DB_USER=alpha_pos
USE_REDIS=True
CORS_ALLOWED_ORIGINS=http://localhost:5181

# Ports.
PANEL_PORT=5181
WEB_PORT=8000

# Override only if the backend checkout lives elsewhere.
# ALPHA_POS_DIR=../alpha_pos

# Sentry — leave VITE_SENTRY_DSN empty to disable in the build.
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_RATE=0.1
VITE_SENTRY_REPLAY_RATE=0
VITE_SENTRY_PII=false
