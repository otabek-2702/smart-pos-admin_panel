# Copy this file to .env.production / .env.staging and fill in real values.
# In local dev, leave this file alone — Vite's proxy (vite.config.ts) handles
# the API host without any env variables.

# Backend API host. Leave empty in dev to use the Vite proxy (recommended).
# In staging/prod, set to the deployed backend URL — without trailing slash.
# The backend must have django-cors-headers configured to allow this origin.
#
# Examples:
#   VITE_API_HOST=https://api.smart-pos.example.com
#   VITE_API_HOST=https://staging-api.smart-pos.example.com
VITE_API_HOST=
